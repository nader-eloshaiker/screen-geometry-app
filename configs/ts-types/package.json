{
  "name": "@screengeometry/types",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts"
    },
    "./vite.d": {
      "types": "./src/vite.d.ts"
    },
    "./react.d": {
      "types": "./src/react.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@screengeometry/eslint-config": "workspace:*",
    "@screengeometry/prettier-config": "workspace:*",
    "@screengeometry/ts-config": "workspace:*"
  },
  "peerDependencies": {
    "@types/node": "^20.11.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "typescript": "^5.4.2",
    "vite": "^5.0.10",
    "vitest": "^1.3.1"
  }
}
