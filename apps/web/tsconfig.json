{
  "extends": "@screengeometry/ts-config/react",
  "display": "Components",
  "compilerOptions": {
    "types": ["vitest/globals", "@screengeometry/types/react.d", "@screengeometry/types/vite.d"],
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@constants/*": ["./src/constants/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@models/*": ["./src/models/*"],
      "@pages/*": ["./src/pages/*"],
      "@routes/*": ["./src/routes/*"],
      "@test/*": ["./src/test/*"],
      "@screengeometry/components": ["../../packages/components/src"],
      "@screengeometry/openapi": ["../../packages/openapi/src"],
      "@screengeometry/server": ["../../packages/server/src"],
      "@screengeometry/serviceworker": ["../../packages/serviceworker/src"],
      "@screengeometry/utils": ["../../packages/utils/src"]
    }
  },
  "include": ["./src"],
  "exclude": ["node_modules/**/*", "dist/**/*", "coverage/**/*"]
}
