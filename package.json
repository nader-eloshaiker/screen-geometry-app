{
  "name": "screen-geometry-app",
  "version": "1.3.5",
  "homepage": "https://github.com/nader-eloshaiker/screen-geometry-app",
  "private": false,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Nader Eloshaiker",
    "url": "https://github.com/nader-eloshaiker"
  },
  "packageManager": "pnpm@8.15.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "scripts": {
    "preinstall": "pnpx only-allow pnpm",
    "postinstall": "syncpack fix-mismatches",
    "dev": "pnpm  --parallel --filter \"./**\" dev",
    "dev:e2e": "vite --mode development --port 3000",
    "build": "tsc && vite build",
    "build:prod": "pnpm build",
    "build:dev": "tsc && vite build --mode development",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "preview": "pnpm  --parallel --filter \"./**\" preview",
    "gen:spec": "orval --config ./orval.config.ts",
    "prepare": "husky",
    "test": "vitest --coverage",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "test:ci": "vitest --run --coverage",
    "test:badge": "vitest --run --coverage && node tools/createCoverageBadges.cjs",
    "e2e": "pnpm exec playwright test",
    "e2e:ui": "pnpm exec playwright test --ui",
    "e2e:codegen": "pnpm exec playwright codegen localhost:3000",
    "e2e:install": "pnpm exec playwright install --with-deps",
    "e2e:report": "pnpm exec playwright show-report",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "sb": "storybook dev -p 6006",
    "sb:test": "test-storybook -- --coverage",
    "sb:build": "storybook build",
    "report": "pnpm report:sb && pnpm report:test",
    "report:sb": "storybook build --docs --output-dir=./reports/storybook",
    "report:test": "pnpm test:ci"
  },
  "dependencies": {
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@screengeometry/eslint-config": "1.0.0",
    "@screengeometry/prettier-config": "1.0.0",
    "@screengeometry/ts-config": "1.0.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-prettier": "^3.1.3",
    "@types/node": "^20.11.2",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/ui": "^1.3.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-storybook": "^0.6.15",
    "eslint-plugin-tailwindcss": "^3.14.0",
    "husky": "^9.0.11",
    "jsdom": "^23.0.1",
    "jsonfile": "^6.1.0",
    "lint-staged": "^15.2.2",
    "mkdirp": "^3.0.1",
    "prettier": "^3.1.0",
    "storybook": "^7.6.17",
    "syncpack": "^12.3.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.3.1"
  },
  "browserslist": [
    "defaults"
  ],
  "lint-staged": {
    "**/*.{ts,tsx,js,json,yaml,yml} !(src/openapi/generated/**/*)": "pnpm run lint:fix",
    "*.{ts,tsx,js,csss,json,yaml,yml,md*}": "pnpm run format"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
