{
  "extends": "@screengeometry/ts-config/node",
  "display": "Main",
  "compilerOptions": {
    "types": ["vitest/globals", "@screengeometry/types/react.d", "@screengeometry/types/vite.d"],
    "paths": {
      "@screengeometry/*": ["./packages/*", "./packages/*/src"]
    }
  },
  "include": ["package.json", "@screengeometry/types/react.d", "@screengeometry/types/vite.d"],
  "exclude": ["node_modules/", "dist/", "coverage/"]
}
