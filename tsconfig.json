{
  "extends": "@screengeometry/typescript-config/tsconfig.react.json",
  "compilerOptions": {
    /* paths */
    "baseUrl": ".",
    "paths": {
      // "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@constants/*": ["./src/constants/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@pages/*": ["./src/pages/*"],
      "@routes/*": ["./src/routes/*"],
      "@test/*": ["./src/test/*"]
    }
  },
  "include": ["./src/**/*", "./packages/typescript-config/types/*.d.ts"],
  "exclude": ["node_modules", "coverage", "dist", "build"]
}
