{
  "extends": "@screengeometry/typescript-config/tsconfig.react.json",
  "compilerOptions": {
    /* paths */
    "types": ["vitest/globals"],
    "baseUrl": ".",
    "paths": {
      // "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@constants/*": ["./src/constants/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@models/*": ["./src/models/*"],
      "@pages/*": ["./src/pages/*"],
      "@routes/*": ["./src/routes/*"],
      "@server/*": ["src/server/*"],
      "@test/*": ["./src/test/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*", "packages/openapi/src/axios/useApiAxios.ts"],
  "exclude": ["node_modules", "coverage", "dist", "build"]
}
