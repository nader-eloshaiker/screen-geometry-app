{
  "extends": "@screengeometry/typescript-config/tsconfig.react.json",
  "compilerOptions": {
    /* paths */
    "types": ["vitest/globals"],
    "baseUrl": ".",
    "paths": {
      // "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@constants/*": ["./src/constants/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@pages/*": ["./src/pages/*"],
      "@routes/*": ["./src/routes/*"],
      "@test/*": ["./src/test/*"]
    }
  },
  "include": [
    "src/**/*",
    "packages/serviceworker/src/BrowserServiceWorker.ts",
    "packages/utils/src/DataTransformation.ts",
    "packages/utils/src/RandomGenerator.ts",
    "packages/utils/src/ScreenCalc.ts"
  ],
  "exclude": ["node_modules", "coverage", "dist", "build"]
}
