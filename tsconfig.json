{
  "extends": "@screengeometry/ts-config/react",
  "display": "Main",
  "compilerOptions": {
    "types": ["@screengeometry/types/react", "@screengeometry/types/vite"],

    "baseUrl": ".",
    "paths": {
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@constants/*": ["./src/constants/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@pages/*": ["./src/pages/*"],
      "@routes/*": ["./src/routes/*"],
      "@test/*": ["./src/test/*"]
    }
  },
  "include": ["./src/**/*", "vite.config.ts", "package.json"]
}
