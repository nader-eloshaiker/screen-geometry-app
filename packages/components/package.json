{
  "name": "@screengeometry/components",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "index.ts",
  "exports": {
    "./autocomplete": "./src/autocomplete/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./listinputfield": "./src/listinputfield/index.ts",
    "./notification": "./src/notification/index.ts",
    "./overlayinputfield": "./src/overlayinputfield/index.ts",
    "./skeleton": "./src/skeleton/index.ts"
  },
  "scripts": {
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest --coverage",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "test:ci": "vitest --run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "sb": "storybook dev -p 6006",
    "sb:test": "test-storybook -- --coverage",
    "sb:build": "storybook build",
    "report": "pnpm report:sb && pnpm report:test",
    "report:sb": "storybook build --docs --output-dir=./reports/storybook",
    "report:test": "pnpm test:ci"
  },
  "dependencies": {
    "@react-hook/resize-observer": "^1.2.6",
    "@screengeometry/utils": "1.0.0",
    "autoprefixer": "^10.4.17",
    "axios": "^1.6.7",
    "clsx": "^2.1.0",
    "daisyui": "^4.4.19",
    "eslint": "^8.56.0",
    "postcss": "^8.4.35",
    "prettier": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.8",
    "tailwind-merge": "^2.2.0",
    "tailwind-styled-components": "^2.2.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@screengeometry/eslint-config": "1.0.0",
    "@screengeometry/prettier-config": "1.0.0",
    "@screengeometry/tailwind-config": "1.0.0",
    "@screengeometry/ts-config": "1.0.0",
    "@screengeometry/types": "1.0.0",
    "@types/node": "^20.11.2",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.17",
    "@storybook/addon-coverage": "^1.0.0",
    "@storybook/addon-essentials": "^7.6.17",
    "@storybook/addon-interactions": "^7.6.17",
    "@storybook/addon-links": "^7.6.17",
    "@storybook/addon-onboarding": "^1.0.11",
    "@storybook/addon-themes": "^7.6.17",
    "@storybook/blocks": "^7.6.17",
    "@storybook/react": "^7.6.17",
    "@storybook/react-vite": "^7.6.17",
    "@storybook/test": "^7.6.17",
    "@storybook/test-runner": "^0.16.0",
    "@testing-library/jest-dom": "^6.1.6",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-prettier": "^3.1.3",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  }
}
